#!/usr/bin/env bash
# phpick — per-project PHP version routing for composer and php.
# Pin per project:  composer config platform.php 8.4.15
# https://github.com/phpick/phpick

set -eu

PHPICK_VERSION="0.2.0"
PHPICK_REPO_DEFAULT="phpick/phpick"

invoked_as=$(basename -- "$0")

# Resolve our own real path so we can skip ourselves when walking PATH.
self_real=""
if command -v readlink >/dev/null 2>&1 && readlink -f -- "$0" >/dev/null 2>&1; then
    self_real=$(readlink -f -- "$0")
elif command -v realpath >/dev/null 2>&1; then
    self_real=$(realpath -- "$0" 2>/dev/null || echo "$0")
else
    self_real="$0"
fi

warn() { printf "phpick: %s\n" "$*" >&2; }

# Resolve a candidate path to its canonical form (follow symlinks).
canon() {
    local p="$1"
    if command -v readlink >/dev/null 2>&1 && readlink -f -- "$p" >/dev/null 2>&1; then
        readlink -f -- "$p"
    elif command -v realpath >/dev/null 2>&1; then
        realpath -- "$p" 2>/dev/null || echo "$p"
    else
        echo "$p"
    fi
}

# Find a binary named $1 on PATH, skipping any entry that resolves to us.
find_real_binary() {
    local name="$1"
    local old_ifs="$IFS"
    IFS=:
    local p candidate cand_real
    for p in $PATH; do
        [ -z "$p" ] && p=.
        candidate="$p/$name"
        if [ -x "$candidate" ] && [ ! -d "$candidate" ]; then
            cand_real=$(canon "$candidate")
            if [ "$cand_real" != "$self_real" ]; then
                IFS="$old_ifs"
                printf "%s" "$candidate"
                return 0
            fi
        fi
    done
    IFS="$old_ifs"
    return 1
}

# Find a php binary for major.minor version $1 (e.g. "8.4").
find_php_version() {
    local ver="$1"
    local compact="${ver//./}"
    local name found d prefix

    for name in "php${ver}" "php${compact}"; do
        if found=$(find_real_binary "$name"); then
            printf "%s" "$found"
            return 0
        fi
    done

    # Homebrew (macOS + linuxbrew)
    if command -v brew >/dev/null 2>&1; then
        prefix=$(brew --prefix "php@${ver}" 2>/dev/null || true)
        if [ -n "$prefix" ] && [ -x "$prefix/bin/php" ]; then
            printf "%s" "$prefix/bin/php"
            return 0
        fi
    fi

    # asdf
    for d in "$HOME"/.asdf/installs/php/"${ver}".*; do
        if [ -x "$d/bin/php" ]; then printf "%s" "$d/bin/php"; return 0; fi
    done

    # phpenv
    for d in "$HOME"/.phpenv/versions/"${ver}".*; do
        if [ -x "$d/bin/php" ]; then printf "%s" "$d/bin/php"; return 0; fi
    done

    # Laravel Herd (macOS)
    local herd_bin="$HOME/Library/Application Support/Herd/bin"
    if [ -x "$herd_bin/php${ver}" ]; then
        printf "%s" "$herd_bin/php${ver}"
        return 0
    fi

    return 1
}

# Walk up from $PWD to find the nearest directory containing composer.json.
find_project_root() {
    local dir="$PWD"
    while [ -n "$dir" ] && [ "$dir" != "/" ]; do
        if [ -f "$dir/composer.json" ]; then
            printf "%s" "$dir"
            return 0
        fi
        dir=$(dirname -- "$dir")
    done
    return 1
}

# Read config.platform.php from composer.json, reduce to major.minor.
read_pinned_version() {
    local composer_json="$1"
    local parser_php="$2"
    "$parser_php" -r '
$path = $argv[1];
$raw = @file_get_contents($path);
if ($raw === false) { exit(1); }
$data = @json_decode($raw, true);
if (!is_array($data)) { exit(1); }
$v = isset($data["config"]["platform"]["php"]) ? $data["config"]["platform"]["php"] : null;
if (!$v) { exit(1); }
if (preg_match("/^(\d+\.\d+)/", $v, $m)) { echo $m[1]; exit(0); }
exit(1);
' -- "$composer_json" 2>/dev/null
}

# Fetch $1 (URL or local path) and print to stdout.
fetch_to_stdout() {
    local url="$1"
    case "$url" in
        http://*|https://*|file://*)
            if command -v curl >/dev/null 2>&1; then
                curl -fsSL "$url"
            elif command -v wget >/dev/null 2>&1; then
                wget -qO- "$url"
            else
                warn "need curl or wget to fetch $url"
                return 1
            fi
            ;;
        *)
            if [ -f "$url" ]; then
                cat -- "$url"
            else
                warn "not a URL and no such file: $url"
                return 1
            fi
            ;;
    esac
}

raw_base_url() {
    local ref="${PHPICK_REF:-main}"
    local repo="${PHPICK_REPO:-$PHPICK_REPO_DEFAULT}"
    printf 'https://raw.githubusercontent.com/%s/%s' "$repo" "$ref"
}

remote_version_url() {
    if [ -n "${PHPICK_REMOTE_VERSION_URL:-}" ]; then
        printf '%s' "$PHPICK_REMOTE_VERSION_URL"
    else
        printf '%s/bin/phpick' "$(raw_base_url)"
    fi
}

install_url() {
    if [ -n "${PHPICK_INSTALL_URL:-}" ]; then
        printf '%s' "$PHPICK_INSTALL_URL"
    else
        printf '%s/install.sh' "$(raw_base_url)"
    fi
}

get_remote_version() {
    local content
    if ! content=$(fetch_to_stdout "$(remote_version_url)"); then
        return 1
    fi
    printf '%s\n' "$content" | sed -n 's/^PHPICK_VERSION="\([^"]*\)".*/\1/p' | head -n 1
}

cmd_check_update() {
    local remote newer
    if ! remote=$(get_remote_version) || [ -z "$remote" ]; then
        warn "could not determine remote version"
        exit 1
    fi
    if [ "$remote" = "$PHPICK_VERSION" ]; then
        echo "phpick $PHPICK_VERSION is up to date"
        exit 0
    fi
    newer=$(printf '%s\n%s\n' "$PHPICK_VERSION" "$remote" | sort -V | tail -n 1)
    if [ "$newer" = "$remote" ]; then
        echo "phpick $PHPICK_VERSION -> $remote available (run 'phpick update' to upgrade)"
    else
        echo "phpick $PHPICK_VERSION is ahead of remote $remote"
    fi
    exit 0
}

cmd_update() {
    local url tmp
    url=$(install_url)
    tmp=$(mktemp) || { warn "mktemp failed"; exit 1; }
    # shellcheck disable=SC2064
    trap "rm -f '$tmp'" EXIT
    echo "phpick: fetching installer from $url"
    if ! fetch_to_stdout "$url" > "$tmp"; then
        warn "could not download installer from $url"
        exit 1
    fi
    bash "$tmp"
}

update_stamp_path() {
    printf '%s' "${PHPICK_UPDATE_STAMP:-${XDG_CACHE_HOME:-$HOME/.cache}/phpick/last-check}"
}

# Gate: should the shim do its daily update check on this invocation?
should_check_update() {
    [ "${PHPICK_NO_UPDATE_CHECK:-0}" = "1" ] && return 1
    # Only bother users with interactive terminals — unless explicitly forced
    # (used by tests to exercise the code path on captured stderr).
    if [ "${PHPICK_UPDATE_CHECK_SYNC:-0}" != "1" ]; then
        [ -t 2 ] || return 1
    fi
    local stamp today prev
    stamp=$(update_stamp_path)
    today=$(date -u +%Y-%m-%d 2>/dev/null) || return 1
    if [ -f "$stamp" ]; then
        prev=$(cat -- "$stamp" 2>/dev/null || true)
        [ "$prev" = "$today" ] && return 1
    fi
    # Stamp first so a failing network doesn't cause repeat checks all day.
    mkdir -p -- "$(dirname -- "$stamp")" 2>/dev/null || return 1
    printf '%s\n' "$today" > "$stamp" 2>/dev/null || return 1
    return 0
}

# Print one line to stderr if a newer version is published. Silent on
# same-version, network error, or parse failure.
run_update_check_quiet() {
    local remote newer
    remote=$(get_remote_version 2>/dev/null) || return 0
    [ -n "$remote" ] || return 0
    [ "$remote" = "$PHPICK_VERSION" ] && return 0
    newer=$(printf '%s\n%s\n' "$PHPICK_VERSION" "$remote" | sort -V | tail -n 1)
    [ "$newer" = "$remote" ] || return 0
    printf 'phpick: new version available: %s -> %s (run `phpick update`)\n' \
        "$PHPICK_VERSION" "$remote" >&2
}

# Fire-and-forget daily update check. Detached from stdin/stdout so it can't
# block the exec'd command; stderr stays attached so the hint still reaches
# the user. PHPICK_UPDATE_CHECK_SYNC=1 runs it inline (used by tests).
maybe_background_update_check() {
    should_check_update || return 0
    if [ "${PHPICK_UPDATE_CHECK_SYNC:-0}" = "1" ]; then
        run_update_check_quiet
    else
        (run_update_check_quiet) </dev/null >/dev/null &
        disown 2>/dev/null || true
    fi
}

# --- main ---

case "$invoked_as" in
    phpick)
        # Direct invocation: print info and exit.
        case "${1:-}" in
            -v|--version) echo "phpick $PHPICK_VERSION"; exit 0 ;;
            update|self-update) cmd_update; exit 0 ;;
            check-update) cmd_check_update ;;
            -h|--help|"")
                cat <<EOF
phpick $PHPICK_VERSION — per-project PHP version routing

Usage:
  Run 'composer' or 'php' inside a project; phpick picks the PHP
  version pinned in composer.json under config.platform.php.

Pin a project:
  composer config platform.php 8.4.15

Commands:
  update            reinstall phpick from \$PHPICK_REPO@\$PHPICK_REF
  check-update      report whether a newer phpick is published

Flags:
  -v, --version     print version
  -h, --help        show this help

Env overrides:
  PHPICK_REF                   git ref (default: main)
  PHPICK_REPO                  owner/repo (default: $PHPICK_REPO_DEFAULT)
  PHPICK_INSTALL_URL           full URL to install.sh (overrides REF/REPO)
  PHPICK_REMOTE_VERSION_URL    full URL to bin/phpick for version check
  PHPICK_NO_UPDATE_CHECK=1     disable the daily background update check
  PHPICK_UPDATE_STAMP          override the stamp file (default:
                               \${XDG_CACHE_HOME:-~/.cache}/phpick/last-check)
EOF
                exit 0 ;;
            *) warn "unknown argument '$1'"; exit 2 ;;
        esac
        ;;
esac

# For composer/php dispatch we always need *some* working php to parse JSON.
if ! real_php=$(find_real_binary php); then
    echo "phpick: no 'php' binary found on PATH" >&2
    exit 127
fi

pinned_php="$real_php"
if project_root=$(find_project_root); then
    if version=$(read_pinned_version "$project_root/composer.json" "$real_php"); then
        if php_bin=$(find_php_version "$version"); then
            pinned_php="$php_bin"
        else
            warn "composer.json pins php $version but no matching binary was found; using default php"
        fi
    fi
fi

case "$invoked_as" in
    php)
        maybe_background_update_check
        exec "$pinned_php" "$@"
        ;;
    composer)
        if ! real_composer=$(find_real_binary composer); then
            echo "phpick: no 'composer' binary found on PATH" >&2
            exit 127
        fi
        maybe_background_update_check
        exec "$pinned_php" "$real_composer" "$@"
        ;;
    *)
        echo "phpick: invoked as unknown name '$invoked_as' (expected php, composer, or phpick)" >&2
        exit 1
        ;;
esac
